<Window x:Class="LLOIS.Views.AddEditOrdinanceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Ordinance" Height="760" Width="720"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource BgPrimaryBrush}">

    <Window.Resources>

        <!-- ── Spacing scale (use these instead of ad-hoc margins) ─────── -->
        <Thickness x:Key="SectionGap">0,22,0,0</Thickness>
        <Thickness x:Key="FieldGap">0,14,0,0</Thickness>
        <Thickness x:Key="LabelGap">0,0,0,5</Thickness>

        <!-- ── Field label ──────────────────────────────────────────────── -->
        <Style TargetType="TextBlock" x:Key="Label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="{StaticResource LabelGap}"/>
        </Style>

        <!-- ── Required-field asterisk accent ──────────────────────────── -->
        <Style TargetType="Run" x:Key="ReqMark">
            <Setter Property="Foreground" Value="{DynamicResource DangerFgBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- ── Section header (icon badge + title + subtitle) ─────────── -->
        <Style TargetType="TextBlock" x:Key="SectionTitle">
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="SectionSubtitle">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}"/>
            <Setter Property="Margin" Value="0,1,0,0"/>
        </Style>

        <!-- ── Card container for each section ─────────────────────────── -->
        <Style TargetType="Border" x:Key="SectionCard">
            <Setter Property="Background" Value="{DynamicResource BgSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderThinBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="18,16"/>
        </Style>

        <!-- ── Icon badge (small colored circle behind an emoji) ───────── -->
        <Style TargetType="Border" x:Key="IconBadge">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="{DynamicResource BrandVeryLightBrush}"/>
        </Style>

        <!-- ── Secondary (Cancel) button — quiet ───────────────────────── -->
        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderMedBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource BgHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Primary (Save) button — strong ───────────────────────────── -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{DynamicResource BrandBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.78"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <DockPanel Margin="0">

        <!-- ════════════════════════════════════════════════════════════
             HEADER — sticky, theme-aware, uses BrandBrush so it tracks
             light/dark mode like the rest of the app.
        ════════════════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource BrandBrush}"
                Padding="22,16">
            <StackPanel>
                <TextBlock x:Name="WindowTitle" Text="Add New Ordinance"
                           Foreground="White" FontSize="17" FontWeight="Bold"/>
                <TextBlock Text="Fill in the details below. Fields marked with * are required."
                           Foreground="#C8DCFF" FontSize="11.5" Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <!-- ════════════════════════════════════════════════════════════
             FOOTER — sticky action bar, primary action right-aligned
             and visually dominant.
        ════════════════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource BgSecondaryBrush}"
                BorderBrush="{DynamicResource BorderThinBrush}"
                BorderThickness="0,1,0,0"
                Padding="22,14">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           Text="* Required fields"
                           FontSize="11"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CancelBtn" Content="Cancel" Width="92" Margin="0,0,10,0"
                            Style="{StaticResource SecondaryBtn}" Click="CancelBtn_Click"/>
                    <Button x:Name="SaveBtn" Content="💾  Save Ordinance" Width="160"
                            Style="{StaticResource PrimaryBtn}" Click="SaveBtn_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ════════════════════════════════════════════════════════════
             FORM BODY
        ════════════════════════════════════════════════════════════ -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="22,18,22,18">

                <!-- Error Banner — now theme-aware via Danger brushes -->
                <Border x:Name="ErrorBanner"
                        Background="{DynamicResource DangerBgBrush}"
                        BorderBrush="{DynamicResource DangerBorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="12,10"
                        Margin="0,0,0,16" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠" Foreground="{DynamicResource DangerFgBrush}"
                                   FontSize="14" Margin="0,0,8,0" VerticalAlignment="Top"/>
                        <TextBlock x:Name="ErrorText"
                                   Foreground="{DynamicResource DangerFgBrush}"
                                   TextWrapping="Wrap" FontSize="12.5"/>
                    </StackPanel>
                </Border>

                <!-- ── Section: Identity ─────────────────────────────── -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Style="{StaticResource IconBadge}">
                                <TextBlock Text="📋" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Ordinance Identity" Style="{StaticResource SectionTitle}"/>
                                <TextBlock Text="Core identifying information" Style="{StaticResource SectionSubtitle}"/>
                            </StackPanel>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource Label}">
                                    Ordinance Number <Run Text="*" Style="{StaticResource ReqMark}"/>
                                </TextBlock>
                                <TextBox x:Name="OrdNumberBox" Height="34"
                                         Style="{StaticResource PlaceholderTextBox}"
                                         Tag="e.g. ORD-2024-001"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource Label}">
                                    Series Number <Run Text="*" Style="{StaticResource ReqMark}"/>
                                </TextBlock>
                                <TextBox x:Name="SeriesBox" Height="34"
                                         Style="{StaticResource PlaceholderTextBox}"
                                         Tag="e.g. Series of 2024, No. 1"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Margin="{StaticResource FieldGap}">
                            <TextBlock Style="{StaticResource Label}">
                                Title <Run Text="*" Style="{StaticResource ReqMark}"/>
                            </TextBlock>
                            <TextBox x:Name="TitleBox" Height="34"
                                     Style="{StaticResource PlaceholderTextBox}"
                                     Tag="Official title of the ordinance"/>
                        </StackPanel>

                        <StackPanel Margin="{StaticResource FieldGap}">
                            <TextBlock Style="{StaticResource Label}">
                                Subject <Run Text="*" Style="{StaticResource ReqMark}"/>
                            </TextBlock>
                            <TextBox x:Name="SubjectBox" Height="64"
                                     Style="{StaticResource PlaceholderTextBox}"
                                     Tag="Full subject / long title of the ordinance"
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Padding="8,8"/>
                        </StackPanel>

                        <Grid Margin="{StaticResource FieldGap}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource Label}">
                                    Type <Run Text="*" Style="{StaticResource ReqMark}"/>
                                </TextBlock>
                                <ComboBox x:Name="TypeCombo" Height="34">
                                    <ComboBoxItem Content="Regulatory"/>
                                    <ComboBoxItem Content="Revenue"/>
                                    <ComboBoxItem Content="Administrative"/>
                                    <ComboBoxItem Content="Penal"/>
                                    <ComboBoxItem Content="Appropriation"/>
                                    <ComboBoxItem Content="Other"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource Label}">
                                    Status <Run Text="*" Style="{StaticResource ReqMark}"/>
                                </TextBlock>
                                <ComboBox x:Name="StatusCombo" Height="34">
                                    <ComboBoxItem Content="In Effect"/>
                                    <ComboBoxItem Content="Amended"/>
                                    <ComboBoxItem Content="Superseded"/>
                                    <ComboBoxItem Content="Repealed"/>
                                    <ComboBoxItem Content="Under Review"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── Section: Authorship ───────────────────────────── -->
                <Border Style="{StaticResource SectionCard}" Margin="{StaticResource SectionGap}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Style="{StaticResource IconBadge}">
                                <TextBlock Text="👤" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Authorship &amp; Committee" Style="{StaticResource SectionTitle}"/>
                                <TextBlock Text="Who sponsored and reviewed this ordinance" Style="{StaticResource SectionSubtitle}"/>
                            </StackPanel>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource Label}">
                                    Sponsor / Author <Run Text="*" Style="{StaticResource ReqMark}"/>
                                </TextBlock>
                                <TextBox x:Name="SponsorBox" Height="34"
                                         Style="{StaticResource PlaceholderTextBox}"
                                         Tag="e.g. Hon. Juan dela Cruz"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Committee" Style="{StaticResource Label}"/>
                                <TextBox x:Name="CommitteeBox" Height="34"
                                         Style="{StaticResource PlaceholderTextBox}"
                                         Tag="e.g. Committee on Environment"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── Section: Dates ────────────────────────────────── -->
                <Border Style="{StaticResource SectionCard}" Margin="{StaticResource SectionGap}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Style="{StaticResource IconBadge}">
                                <TextBlock Text="📅" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Important Dates" Style="{StaticResource SectionTitle}"/>
                                <TextBlock Text="Legislative timeline milestones" Style="{StaticResource SectionSubtitle}"/>
                            </StackPanel>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Date Passed" Style="{StaticResource Label}"/>
                                <DatePicker x:Name="DatePassedPicker" Height="34"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Approved by Mayor" Style="{StaticResource Label}"/>
                                <DatePicker x:Name="DateApprovedPicker" Height="34"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Date Published" Style="{StaticResource Label}"/>
                                <DatePicker x:Name="DatePublishedPicker" Height="34"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── Section: Relationships ────────────────────────── -->
                <Border Style="{StaticResource SectionCard}" Margin="{StaticResource SectionGap}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Style="{StaticResource IconBadge}">
                                <TextBlock Text="🔗" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Ordinance Relationships" Style="{StaticResource SectionTitle}"/>
                                <TextBlock Text="Optional — link to related ordinances" Style="{StaticResource SectionSubtitle}"/>
                            </StackPanel>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Amends Ordinance No." Style="{StaticResource Label}"/>
                                <TextBox x:Name="AmendsBox" Height="34"
                                         Style="{StaticResource PlaceholderTextBox}"
                                         Tag="e.g. ORD-2020-001"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Supersedes Ordinance No." Style="{StaticResource Label}"/>
                                <TextBox x:Name="SupersedesBox" Height="34"
                                         Style="{StaticResource PlaceholderTextBox}"
                                         Tag="e.g. ORD-2015-010"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="{StaticResource FieldGap}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Repealed By Ordinance No." Style="{StaticResource Label}"/>
                                <TextBox x:Name="RepealedByBox" Height="34"
                                         Style="{StaticResource PlaceholderTextBox}"
                                         Tag="e.g. ORD-2023-002"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Repeal Reason" Style="{StaticResource Label}"/>
                                <TextBox x:Name="RepealReasonBox" Height="34"
                                         Style="{StaticResource PlaceholderTextBox}"
                                         Tag="Reason for repeal (if applicable)"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── Section: Initial Version (Add mode only) ──────── -->
                <Border x:Name="VersionSectionCard"
                        Style="{StaticResource SectionCard}" Margin="{StaticResource SectionGap}">
                    <StackPanel>
                        <StackPanel x:Name="VersionSectionHeader"
                                    Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Style="{StaticResource IconBadge}"
                                    Background="{DynamicResource AccentGreenLightBrush}">
                                <TextBlock Text="📄" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Initial Version Content" Style="{StaticResource SectionTitle}"/>
                                <TextBlock Text="The first recorded version of this ordinance" Style="{StaticResource SectionSubtitle}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- kept for code-behind compatibility; no longer a separate visual line -->
                        <Separator x:Name="VersionSeparator" Visibility="Collapsed"/>

                        <StackPanel x:Name="VersionSection">
                            <TextBlock Style="{StaticResource Label}" Margin="0,0,0,5">
                                Version Title <Run Text="*" Style="{StaticResource ReqMark}"/>
                            </TextBlock>
                            <TextBox x:Name="VersionTitleBox" Height="34"
                                     Style="{StaticResource PlaceholderTextBox}"
                                     Tag="Title for Version 1"/>

                            <TextBlock Style="{StaticResource Label}" Margin="{StaticResource FieldGap}">
                                Content / Summary <Run Text="*" Style="{StaticResource ReqMark}"/>
                            </TextBlock>
                            <TextBox x:Name="VersionContentBox" Height="76"
                                     Style="{StaticResource PlaceholderTextBox}"
                                     Tag="Describe what this ordinance contains..."
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Padding="8,8"/>

                            <TextBlock Text="Enacted By" Style="{StaticResource Label}" Margin="{StaticResource FieldGap}"/>
                            <TextBox x:Name="EnactedByBox" Height="34"
                                     Style="{StaticResource PlaceholderTextBox}"
                                     Tag="e.g. Ordinance No. 2024-001"/>

                            <TextBlock Margin="{StaticResource FieldGap}" Style="{StaticResource Label}">
                                Date Enacted <Run Text="*" Style="{StaticResource ReqMark}"/>
                            </TextBlock>
                            <DatePicker x:Name="VersionDatePicker" Height="34" HorizontalAlignment="Left" Width="220"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ── Section: PDF Attachment ────────────────────────── -->
                <Border Style="{StaticResource SectionCard}" Margin="{StaticResource SectionGap}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Style="{StaticResource IconBadge}">
                                <TextBlock Text="📎" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Document Attachment" Style="{StaticResource SectionTitle}"/>
                                <TextBlock Text="Attach the original signed PDF (optional)" Style="{StaticResource SectionSubtitle}"/>
                            </StackPanel>
                        </StackPanel>

                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="Browse…" Width="100" Height="34"
                                    Margin="8,0,0,0" Style="{StaticResource SecondaryBtn}"
                                    Click="BrowsePdf_Click"/>
                            <TextBox x:Name="PdfPathBox" IsReadOnly="True" Height="34"
                                     Style="{StaticResource PlaceholderTextBox}"
                                     Tag="No PDF attached"/>
                        </DockPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
