<UserControl x:Class="LLOIS.Views.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:LLOIS"
             Background="{DynamicResource BgPrimaryBrush}">

    <UserControl.Resources>
        <local:NullToVisibilityConverter x:Key="NullToVisibility"/>
        <local:OrdinanceTypeColorConverter x:Key="TypeColorConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar -->
            <ColumnDefinition Width="190"/>
            <!-- Main content area -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════════
             SIDEBAR
        ════════════════════════════════════════════════════════ -->
        <DockPanel Grid.Column="0"
                   Background="{DynamicResource SidebarBgBrush}">

            <!-- App logo / title area -->
            <Border DockPanel.Dock="Top"
                    Padding="16,20,16,16"
                    BorderBrush="#1E2340"
                    BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="LLOIS"
                               Foreground="White"
                               FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="Legislative Info System"
                               Foreground="#4B5280"
                               FontSize="10"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- Bottom: user account area -->
            <Border DockPanel.Dock="Bottom"
                    Padding="14,12"
                    BorderBrush="#1E2340"
                    BorderThickness="0,1,0,0">
                <Button x:Name="UserChipBtn"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="UserChipBtn_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="Transparent" CornerRadius="8" Padding="4">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="32" Height="32" CornerRadius="16"
                                            Background="{DynamicResource BrandBrush}"
                                            Margin="0,0,10,0">
                                        <TextBlock x:Name="SidebarAvatarLabel"
                                                FontSize="13" FontWeight="Bold"
                                                Foreground="White"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock x:Name="SidebarUsernameLabel"
                                                FontSize="12" FontWeight="SemiBold"
                                                Foreground="#E2E8F8"/>
                                        <TextBlock x:Name="SidebarRoleLabel"
                                                FontSize="10" Margin="0,1,0,0"
                                                Foreground="#4B5280"/>
                                    </StackPanel>
                                    <TextBlock Text="▾" Foreground="#4B5280"
                                            FontSize="10" Margin="8,0,0,0"
                                            VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#1A1D2E"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Border>

            <!-- Nav items -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,12,0,0">

                    <!-- MAIN section -->
                    <TextBlock Text="MAIN"
                               Foreground="{DynamicResource SidebarSectionLabelBrush}"
                               FontSize="10" FontWeight="Bold"
                               Margin="16,0,0,6"/>

                    <Button x:Name="NavDashboardBtn"
                            Style="{StaticResource SidebarNavBtnActive}"
                            Click="NavDashboard_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⊞" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="NavOrdinancesBtn"
                            Style="{StaticResource SidebarNavBtn}"
                            Click="NavOrdinances_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📄" FontSize="13" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Ordinances" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="NavReportsBtn"
                            Style="{StaticResource SidebarNavBtn}"
                            Click="NavReports_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" FontSize="13" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Reports" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- ADMIN section -->
                    <TextBlock x:Name="AdminSectionLabel"
                               Text="ADMIN"
                               Foreground="{DynamicResource SidebarSectionLabelBrush}"
                               FontSize="10" FontWeight="Bold"
                               Margin="16,16,0,6"
                               Visibility="Collapsed"/>

                    <Button x:Name="NavUsersBtn"
                            Style="{StaticResource SidebarNavBtn}"
                            Visibility="Collapsed"
                            Click="NavUsers_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👥" FontSize="13" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Users" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="NavAuditBtn"
                            Style="{StaticResource SidebarNavBtn}"
                            Visibility="Collapsed"
                            Click="NavAudit_Click">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔍" FontSize="13" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Audit Log" VerticalAlignment="Center"/>
                            </StackPanel>
                            <!-- Badge for unread count -->
                            <Border x:Name="AuditBadge"
                                    Background="#DC2626"
                                    CornerRadius="8"
                                    MinWidth="18" Height="18"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Margin="0,0,12,0"
                                    Visibility="Collapsed">
                                <TextBlock x:Name="AuditBadgeCount"
                                           Foreground="White"
                                           FontSize="10" FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Padding="4,0"/>
                            </Border>
                        </Grid>
                    </Button>

                </StackPanel>
            </ScrollViewer>
        </DockPanel>

        <!-- ═══════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
        ════════════════════════════════════════════════════════ -->
        <DockPanel Grid.Column="1">

            <!-- ─── TOPBAR ──────────────────────────────────────── -->
            <Border DockPanel.Dock="Top"
                    Background="{DynamicResource TopbarBgBrush}"
                    Padding="20,0" Height="52"
                    BorderBrush="#1E2340"
                    BorderThickness="0,0,0,1">
                <DockPanel VerticalAlignment="Center">

                    <!-- Right: search + theme toggle -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <!-- Search box -->
                        <Border Background="{DynamicResource TopbarSearchBgBrush}"
                                CornerRadius="8" Width="220" Height="34"
                                Margin="0,0,10,0">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left"
                                           Text="🔍" FontSize="13"
                                           Foreground="#4B5280"
                                           VerticalAlignment="Center"
                                           Margin="10,0,6,0"/>
                                <TextBox x:Name="TopSearchBox"
                                         Style="{StaticResource TopbarSearchBox}"
                                         Tag="Search ordinances..."
                                         VerticalAlignment="Center"
                                         KeyDown="SearchBox_KeyDown"/>
                            </DockPanel>
                        </Border>

                        <!-- Theme toggle -->
                        <Button x:Name="ThemeToggleBtn"
                                Style="{StaticResource TopbarBtn}"
                                Width="34" Height="34"
                                Padding="0"
                                ToolTip="Toggle theme"
                                Click="ThemeToggleBtn_Click">
                            <TextBlock x:Name="ThemeIcon" Text="☀" FontSize="16"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>

                        <!-- User dropdown popup (triggered from the sidebar user chip) -->
                        <Popup x:Name="UserPopup"
                               PlacementTarget="{Binding ElementName=ThemeToggleBtn}"
                               Placement="Bottom"
                               StaysOpen="False"
                               AllowsTransparency="True">
                            <Border Background="{DynamicResource BgSecondaryBrush}"
                                    BorderBrush="{DynamicResource BorderThinBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    MinWidth="220"
                                    Margin="0,6,0,0">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="20" ShadowDepth="6"
                                                    Color="#000000" Opacity="0.3"/>
                                </Border.Effect>
                                <StackPanel>
                                    <!-- User info header -->
                                    <Border Padding="16,14,16,14"
                                            BorderBrush="{DynamicResource BorderThinBrush}"
                                            BorderThickness="0,0,0,1">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="36" Height="36" CornerRadius="18"
                                                    Background="{DynamicResource BrandBrush}"
                                                    Margin="0,0,10,0">
                                                <TextBlock x:Name="DropdownAvatarLabel"
                                                           FontSize="14" FontWeight="Bold"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock x:Name="DropdownNameLabel"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock x:Name="DropdownRoleLabel"
                                                           FontSize="11" Margin="0,2,0,0"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Theme toggle row -->
                                    <Button Click="ThemeToggleBtn_Click"
                                            HorizontalContentAlignment="Left"
                                            Padding="16,10"
                                            BorderThickness="0"
                                            Background="Transparent"
                                            Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                        Padding="{TemplateBinding Padding}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock x:Name="PopupThemeIcon" Text="☀" FontSize="14"
                                                                   Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                        <TextBlock x:Name="PopupThemeLabel"
                                                                   Text="Light Mode"
                                                                   FontSize="13"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background"
                                                                Value="{DynamicResource BgHoverBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <Border Height="1" Background="{DynamicResource BorderThinBrush}"/>

                                    <!-- Logout -->
                                    <Button Click="LogoutBtn_Click"
                                            Padding="16,10"
                                            BorderThickness="0"
                                            Background="Transparent"
                                            Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                        Padding="{TemplateBinding Padding}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="🚪" FontSize="14"
                                                                   Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="Logout" FontSize="13"
                                                                   Foreground="{DynamicResource DangerFgBrush}"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background"
                                                                Value="{DynamicResource DangerBgBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <Border Height="4"/>
                                </StackPanel>
                            </Border>
                        </Popup>

                    </StackPanel>

                    <!-- Left: page title (updated by nav) -->
                    <TextBlock x:Name="PageTitleLabel"
                               Text="Dashboard"
                               Foreground="White"
                               FontSize="16" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- ─── PAGE CONTENT (swapped by nav buttons) ──────── -->
            <!-- ContentControl hosts Dashboard or Ordinances view -->
            <ContentControl x:Name="PageHost"
                            Background="{DynamicResource BgPrimaryBrush}"/>

        </DockPanel>
    </Grid>
</UserControl>
