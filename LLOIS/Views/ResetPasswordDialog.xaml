<Window x:Class="LLOIS.Views.ResetPasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reset Password" Height="240" Width="360"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="24">
        <TextBlock x:Name="HeaderText" FontSize="14" FontWeight="Bold" Margin="0,0,0,16"/>

        <TextBlock Text="New Password *" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <PasswordBox x:Name="PasswordBox" Padding="6,4" Margin="0,0,0,10"/>

        <TextBlock Text="Confirm Password *" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <PasswordBox x:Name="ConfirmBox" Padding="6,4" Margin="0,0,0,10"/>

        <TextBlock x:Name="ErrText" Foreground="Red" Margin="0,0,0,8" Visibility="Collapsed"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="80" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Reset" Width="80" Click="Reset_Click"
                    Background="#8b1a1a" Foreground="White"/>
        </StackPanel>
    </StackPanel>
</Window>
