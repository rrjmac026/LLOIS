<Window x:Class="LLOIS.Views.AddUserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add User" Height="360" Width="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Text="New User" FontSize="15" FontWeight="Bold" Margin="0,0,0,16"/>

            <TextBlock Text="Username *" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox x:Name="UsernameBox" Padding="6,4" Margin="0,0,0,10"/>

            <TextBlock Text="Password *" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <PasswordBox x:Name="PasswordBox" Padding="6,4" Margin="0,0,0,10"/>

            <TextBlock Text="Confirm Password *" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <PasswordBox x:Name="ConfirmBox" Padding="6,4" Margin="0,0,0,10"/>

            <TextBlock Text="Role *" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <ComboBox x:Name="RoleCombo" Margin="0,0,0,16">
                <ComboBoxItem Content="Viewer" IsSelected="True"/>
                <ComboBoxItem Content="Encoder"/>
                <ComboBoxItem Content="Admin"/>
            </ComboBox>

            <TextBlock x:Name="ErrText" Foreground="Red" Margin="0,0,0,8" Visibility="Collapsed"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="80" Margin="0,0,8,0" Click="Cancel_Click"/>
                <Button Content="Create" Width="80" Click="Create_Click"
                        Background="#2d0a4e" Foreground="White"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>