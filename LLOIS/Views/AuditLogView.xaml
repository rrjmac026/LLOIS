<UserControl x:Class="LLOIS.Views.AuditLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BgPrimaryBrush}">

    <DockPanel>

        <!-- Record count / toolbar row -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource BgSecondaryBrush}"
                BorderBrush="{DynamicResource BorderThinBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="↻ Refresh"
                        Style="{StaticResource ActionBtn}"
                        Click="RefreshBtn_Click"/>
                <TextBlock x:Name="RecordCount"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="12"/>
            </DockPanel>
        </Border>

        <DataGrid x:Name="AuditGrid"
                  Margin="16"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  RowHeaderWidth="0"
                  CanUserSortColumns="True"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Timestamp"
                    Binding="{Binding Timestamp, StringFormat=\{0:MM/dd/yyyy HH:mm:ss\}}"
                    Width="160"/>
                <DataGridTextColumn Header="User"
                    Binding="{Binding Username}" Width="130"/>
                <DataGridTextColumn Header="Action"
                    Binding="{Binding Action}" Width="110"/>
                <DataGridTextColumn Header="Details"
                    Binding="{Binding Details}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
