<UserControl x:Class="LLOIS.Views.UserManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BgPrimaryBrush}">

    <DockPanel>

        <!-- Action Bar -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource BgSecondaryBrush}"
                BorderBrush="{DynamicResource BorderThinBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <Button Content="➕ Add User" Width="110" Margin="0,0,8,0"
                        Style="{StaticResource ActionBtn}"
                        Click="AddUserBtn_Click"/>
                <Button Content="🔑 Reset Password" Width="140" Margin="0,0,8,0"
                        Style="{StaticResource ActionBtn}"
                        Click="ResetPasswordBtn_Click"/>
                <Button Content="Deactivate" Width="100" Margin="0,0,8,0"
                        Style="{StaticResource ActionBtn}"
                        Click="DeactivateBtn_Click"/>
                <Button Content="Reactivate" Width="100"
                        Style="{StaticResource ActionBtn}"
                        Click="ReactivateBtn_Click"/>
            </StackPanel>
        </Border>

        <DataGrid x:Name="UsersGrid"
                  Margin="16"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  RowHeaderWidth="0"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="160"/>
                <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="120"/>
                <DataGridTextColumn Header="Active" Binding="{Binding IsActive}" Width="80"/>
                <DataGridTextColumn Header="Created" Binding="{Binding CreatedAt, StringFormat=\{0:MM/dd/yyyy\}}" Width="110"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
