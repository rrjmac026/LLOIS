<Window x:Class="LLOIS.Views.ReportsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LLOIS — Reports" Height="600" Width="860"
        WindowStartupLocation="CenterOwner" Loaded="Window_Loaded">

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#1a3a6b" Padding="16,12">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="🖨️ Print / Export" Width="140"
                        Background="White" FontWeight="SemiBold"
                        Click="PrintBtn_Click"/>
                <TextBlock Text="📊 Reports" Foreground="White"
                           FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Report Selector Tabs -->
        <TabControl x:Name="ReportTabs" DockPanel.Dock="Top" Height="42"
                    SelectionChanged="ReportTabs_SelectionChanged"
                    BorderThickness="0,0,0,1">
            <TabItem Header="By Year"/>
            <TabItem Header="By Status"/>
            <TabItem Header="Repealed"/>
            <TabItem Header="Amended"/>
            <TabItem Header="All Ordinances"/>
        </TabControl>

        <!-- Filters Row -->
        <Border DockPanel.Dock="Top" Background="#F5F7FF" Padding="12,8"
                BorderBrush="#DDEEFF" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <!-- Year filter (for By Year tab) -->
                <StackPanel x:Name="YearFilterPanel" Orientation="Horizontal">
                    <TextBlock Text="Year:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="YearCombo" Width="100" SelectionChanged="Filter_Changed"/>
                    <TextBlock Text="  " Width="16"/>
                </StackPanel>

                <!-- Status filter (for By Status tab) -->
                <StackPanel x:Name="StatusFilterPanel" Orientation="Horizontal" Visibility="Collapsed">
                    <TextBlock Text="Status:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="StatusCombo" Width="140" SelectionChanged="Filter_Changed">
                        <ComboBoxItem Content="In Effect" IsSelected="True"/>
                        <ComboBoxItem Content="Amended"/>
                        <ComboBoxItem Content="Superseded"/>
                        <ComboBoxItem Content="Under Review"/>
                    </ComboBox>
                    <TextBlock Text="  " Width="16"/>
                </StackPanel>

                <TextBlock x:Name="RecordCount" VerticalAlignment="Center"
                           Foreground="Gray" FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- Report Grid -->
        <DataGrid x:Name="ReportGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  RowHeaderWidth="0"
                  AlternatingRowBackground="#F8F9FF"
                  CanUserSortColumns="True"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Ord. Number" Binding="{Binding OrdinanceNumber}" Width="130"/>
                <DataGridTextColumn Header="Series" Binding="{Binding SeriesNumber}" Width="160"/>
                <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*"/>
                <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="110"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                <DataGridTextColumn Header="Sponsor" Binding="{Binding Sponsor}" Width="160"/>
                <DataGridTextColumn Header="Date Passed" Binding="{Binding DatePassed}" Width="110"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
