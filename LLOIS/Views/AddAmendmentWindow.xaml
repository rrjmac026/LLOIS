<Window x:Class="LLOIS.Views.AddAmendmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Amendment" Height="660" Width="600"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource BgPrimaryBrush}">

    <Window.Resources>

        <!-- ── Spacing scale ─────────────────────────────────────────── -->
        <Thickness x:Key="FieldGap">0,14,0,0</Thickness>
        <Thickness x:Key="LabelGap">0,0,0,5</Thickness>

        <!-- ── Field label ──────────────────────────────────────────── -->
        <Style TargetType="TextBlock" x:Key="Label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="{StaticResource LabelGap}"/>
        </Style>

        <!-- ── Required-field asterisk (Run, not TextBlock) ───────────── -->
        <Style TargetType="Run" x:Key="ReqMark">
            <Setter Property="Foreground" Value="{DynamicResource DangerFgBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- ── Card container ───────────────────────────────────────── -->
        <Style TargetType="Border" x:Key="SectionCard">
            <Setter Property="Background" Value="{DynamicResource BgSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderThinBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="18,16"/>
        </Style>

        <!-- ── Secondary (Cancel) button ────────────────────────────── -->
        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderMedBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource BgHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Primary (Save) button — amber, matches "Amended" status color ── -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#B8740F"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.78"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <DockPanel Margin="0">

        <!-- ════════════════════════════════════════════════════════════
             HEADER — amber accent so the window is visually distinct
             from the regular ordinance Add/Edit window, while still
             pulling text/icon colors from the theme.
        ════════════════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top" Background="#8A5A0E" Padding="22,16">
            <StackPanel Orientation="Horizontal">
                <Border Width="34" Height="34" CornerRadius="9"
                        Background="#FFFFFF22" Margin="0,0,12,0">
                    <TextBlock Text="📝" FontSize="16"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="WindowTitle" Text="Add Amendment"
                               Foreground="White" FontSize="17" FontWeight="Bold"/>
                    <TextBlock Text="This will be recorded as a new version of the ordinance."
                               Foreground="#F0DCB0" FontSize="11.5" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ════════════════════════════════════════════════════════════
             FOOTER — sticky action bar
        ════════════════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource BgSecondaryBrush}"
                BorderBrush="{DynamicResource BorderThinBrush}"
                BorderThickness="0,1,0,0"
                Padding="22,14">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           Text="* Required fields"
                           FontSize="11"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Width="92" Margin="0,0,10,0"
                            Style="{StaticResource SecondaryBtn}" Click="CancelBtn_Click"/>
                    <Button Content="✓  Add Amendment" Width="170"
                            Style="{StaticResource PrimaryBtn}" Click="SaveBtn_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ════════════════════════════════════════════════════════════
             FORM BODY
        ════════════════════════════════════════════════════════════ -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="22,18,22,18">

                <!-- Error Banner — theme-aware -->
                <Border x:Name="ErrorBanner"
                        Background="{DynamicResource DangerBgBrush}"
                        BorderBrush="{DynamicResource DangerBorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="12,10"
                        Margin="0,0,0,16" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠" Foreground="{DynamicResource DangerFgBrush}"
                                   FontSize="14" Margin="0,0,8,0" VerticalAlignment="Top"/>
                        <TextBlock x:Name="ErrorText"
                                   Foreground="{DynamicResource DangerFgBrush}"
                                   TextWrapping="Wrap" FontSize="12.5"/>
                    </StackPanel>
                </Border>

                <!-- ── Context card: which ordinance, what version this becomes ── -->
                <Border Background="{DynamicResource VersionNotesBgBrush}"
                        BorderBrush="{DynamicResource BorderThinBrush}"
                        BorderThickness="1" CornerRadius="10" Padding="16,14"
                        Margin="0,0,0,18">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📌" FontSize="13" Margin="0,0,7,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ContextOrdNumber"
                                       FontWeight="Bold" FontSize="14"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="ContextTitle"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="12.5" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        <Border Background="{DynamicResource BgPrimaryBrush}"
                                CornerRadius="6" Padding="9,5" Margin="0,8,0,0"
                                HorizontalAlignment="Left">
                            <TextBlock x:Name="ContextVersionInfo"
                                       Foreground="{DynamicResource VersionNotesFgBrush}"
                                       FontSize="11.5" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ── Section card: amendment details ─────────────────── -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="Amendment Details" FontSize="13.5" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                        <TextBlock Text="Describe the new version this amendment creates"
                                   FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}"
                                   Margin="0,0,0,14"/>

                        <TextBlock Style="{StaticResource Label}" Margin="0,0,0,5">
                            Amendment / New Version Title <Run Text="*" Style="{StaticResource ReqMark}"/>
                        </TextBlock>
                        <TextBox x:Name="TitleBox" Height="34"
                                 Style="{StaticResource PlaceholderTextBox}"
                                 Tag="e.g. Single-Use Plastics Regulation Act (2nd Amendment)"/>

                        <TextBlock Style="{StaticResource Label}" Margin="{StaticResource FieldGap}">
                            What Changed (Content Summary) <Run Text="*" Style="{StaticResource ReqMark}"/>
                        </TextBlock>
                        <TextBox x:Name="ContentBox" Height="86"
                                 Style="{StaticResource PlaceholderTextBox}"
                                 Tag="Describe what this amendment changes or adds..."
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Padding="8,8"/>

                        <TextBlock Text="Amendment Notes (what specifically changed)"
                                   Style="{StaticResource Label}" Margin="{StaticResource FieldGap}"/>
                        <TextBox x:Name="NotesBox" Height="64"
                                 Style="{StaticResource PlaceholderTextBox}"
                                 Tag="e.g. Expanded coverage; added penalty provisions."
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Padding="8,8"/>

                        <Grid Margin="{StaticResource FieldGap}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Enacted By (amending ordinance no.)"
                                           Style="{StaticResource Label}"/>
                                <TextBox x:Name="EnactedByBox" Height="34"
                                         Style="{StaticResource PlaceholderTextBox}"
                                         Tag="e.g. Ordinance No. 2024-005"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource Label}">
                                    Date Enacted <Run Text="*" Style="{StaticResource ReqMark}"/>
                                </TextBlock>
                                <DatePicker x:Name="DatePicker" Height="34"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
