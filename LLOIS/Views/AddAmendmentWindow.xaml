<Window x:Class="LLOIS.Views.AddAmendmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Amendment" Height="480" Width="560"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <DockPanel Margin="0">
        <Border DockPanel.Dock="Top" Background="#7a4b00" Padding="16,12">
            <TextBlock x:Name="WindowTitle" Text="📝 Add Amendment"
                       Foreground="White" FontSize="15" FontWeight="Bold"/>
        </Border>

        <Border DockPanel.Dock="Bottom" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0"
                Padding="16,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="90" Margin="0,0,8,0" Click="CancelBtn_Click"/>
                <Button Content="Add Amendment" Width="130"
                        Background="#7a4b00" Foreground="White" FontWeight="SemiBold"
                        Click="SaveBtn_Click"/>
            </StackPanel>
        </Border>

        <ScrollViewer>
            <StackPanel Margin="20,12">

                <Border x:Name="ErrorBanner" Background="#FFF0F0" BorderBrush="#FFCCCC"
                        BorderThickness="1" CornerRadius="4" Padding="10,8"
                        Margin="0,0,0,10" Visibility="Collapsed">
                    <TextBlock x:Name="ErrorText" Foreground="#CC0000" TextWrapping="Wrap"/>
                </Border>

                <!-- Context info -->
                <Border Background="#FFF8E8" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock x:Name="ContextOrdNumber" FontWeight="Bold" FontSize="13"/>
                        <TextBlock x:Name="ContextTitle" Foreground="Gray" FontSize="12"
                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                        <TextBlock x:Name="ContextVersionInfo" Foreground="#7a4b00"
                                   FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="Amendment / New Version Title *"
                           FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox x:Name="TitleBox" Padding="6,4"
                         PlaceholderText="e.g. Single-Use Plastics Regulation Act (2nd Amendment)"/>

                <TextBlock Text="What Changed (Content Summary) *"
                           FontWeight="SemiBold" Margin="0,10,0,4"/>
                <TextBox x:Name="ContentBox" Height="90" Padding="6,4"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         PlaceholderText="Describe what this amendment changes or adds..."/>

                <TextBlock Text="Amendment Notes (what specifically changed)"
                           FontWeight="SemiBold" Margin="0,10,0,4"/>
                <TextBox x:Name="NotesBox" Height="60" Padding="6,4"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         PlaceholderText="e.g. Expanded coverage; added penalty provisions."/>

                <TextBlock Text="Enacted By (amending ordinance number)"
                           FontWeight="SemiBold" Margin="0,10,0,4"/>
                <TextBox x:Name="EnactedByBox" Padding="6,4"
                         PlaceholderText="e.g. Ordinance No. 2024-005"/>

                <TextBlock Text="Date Enacted *" FontWeight="SemiBold" Margin="0,10,0,4"/>
                <DatePicker x:Name="DatePicker" Height="28"/>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
