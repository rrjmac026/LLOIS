<UserControl x:Class="LLOIS.Views.OrdinancesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:LLOIS"
             Background="{DynamicResource BgPrimaryBrush}">

    <UserControl.Resources>
        <local:NullToVisibilityConverter x:Key="NullToVisibility"/>
        <local:OrdinanceTypeColorConverter x:Key="TypeColorConverter"/>
    </UserControl.Resources>

    <DockPanel>

        <!-- ── Search / filter bar ───────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource BgSecondaryBrush}"
                BorderBrush="{DynamicResource BorderThinBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <DockPanel>
                <!-- Add button (right) -->
                <Button x:Name="AddBtn"
                        DockPanel.Dock="Right"
                        Style="{StaticResource AddBtn}"
                        Content="➕  Add ordinance"
                        Click="AddBtn_Click"
                        Visibility="Collapsed"/>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Search -->
                    <Border Background="{DynamicResource BgPrimaryBrush}"
                            BorderBrush="{DynamicResource BorderThinBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Width="240" Height="34"
                            Margin="0,0,10,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left"
                                       Text="🔍" FontSize="13"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       VerticalAlignment="Center"
                                       Margin="10,0,6,0"/>
                            <TextBox x:Name="SearchBox"
                                     Style="{StaticResource PlaceholderTextBox}"
                                     Tag="Search by ID, title, sponsor…"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     VerticalAlignment="Center"
                                     KeyDown="SearchBox_KeyDown"/>
                        </DockPanel>
                    </Border>

                    <!-- Status filter -->
                    <ComboBox x:Name="StatusFilter" Width="130" Height="34"
                              SelectionChanged="StatusFilter_Changed">
                        <ComboBoxItem Content="All statuses" IsSelected="True"/>
                        <ComboBoxItem Content="In Effect"/>
                        <ComboBoxItem Content="Amended"/>
                        <ComboBoxItem Content="Superseded"/>
                        <ComboBoxItem Content="Repealed"/>
                        <ComboBoxItem Content="Under Review"/>
                    </ComboBox>

                    <!-- Type filter -->
                    <ComboBox x:Name="TypeFilter" Width="120" Height="34" Margin="8,0,0,0"
                              SelectionChanged="TypeFilter_Changed">
                        <ComboBoxItem Content="All types" IsSelected="True"/>
                        <ComboBoxItem Content="Regulatory"/>
                        <ComboBoxItem Content="Revenue"/>
                        <ComboBoxItem Content="Administrative"/>
                        <ComboBoxItem Content="Penal"/>
                        <ComboBoxItem Content="Appropriation"/>
                        <ComboBoxItem Content="Other"/>
                    </ComboBox>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Main split ────────────────────────────────────── -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── LIST PANEL ──────────────────────────────────── -->
            <Border Grid.Column="0"
                    Background="{DynamicResource BgSecondaryBrush}"
                    BorderBrush="{DynamicResource BorderThinBrush}"
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Count header -->
                    <Border DockPanel.Dock="Top"
                            Padding="14,8"
                            BorderBrush="{DynamicResource BorderThinBrush}"
                            BorderThickness="0,0,0,1">
                        <TextBlock x:Name="ResultCount"
                                Text="Loading…"
                                FontSize="12" FontWeight="SemiBold"
                                Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Border>

                    <ListBox x:Name="OrdinanceList"
                            SelectionChanged="OrdinanceList_SelectionChanged"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                            VirtualizingPanel.IsVirtualizing="True">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="14,10,14,10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="4"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                            Text="{Binding OrdinanceNumber}"
                                            FontSize="11" FontWeight="SemiBold"
                                            Foreground="{DynamicResource BrandBrush}"/>

                                    <TextBlock Grid.Row="2"
                                            Text="{Binding Title}"
                                            FontSize="12"
                                            Foreground="{DynamicResource TextPrimaryBrush}"
                                            TextWrapping="NoWrap"
                                            TextTrimming="CharacterEllipsis"/>

                                    <StackPanel Grid.Row="4" Orientation="Horizontal">
                                        <Border CornerRadius="8" Padding="7,3" Margin="0,0,5,0"
                                                Background="{Binding Status, Converter={StaticResource StatusBrushConverter}}">
                                            <TextBlock Text="{Binding Status}"
                                                    FontSize="10" FontWeight="SemiBold"
                                                    Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </Border>

                                        <Border CornerRadius="8" Padding="7,3"
                                                Background="{Binding Type,
                                                    Converter={StaticResource TypeColorConverter},
                                                    ConverterParameter=bg}">
                                            <TextBlock Text="{Binding Type}"
                                                    FontSize="10" FontWeight="SemiBold"
                                                    Foreground="{Binding Type,
                                                        Converter={StaticResource TypeColorConverter},
                                                        ConverterParameter=fg}"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- ── DETAIL PANE ──────────────────────────────────── -->
            <DockPanel Grid.Column="1"
                       Background="{DynamicResource BgPrimaryBrush}">

                <!-- Action bar -->
                <Border DockPanel.Dock="Top"
                        x:Name="ActionBar"
                        Background="{DynamicResource BgSecondaryBrush}"
                        BorderBrush="{DynamicResource BorderThinBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="16,8"
                        Visibility="Collapsed">
                    <DockPanel>
                        <Button x:Name="DeleteBtn"
                                DockPanel.Dock="Right"
                                Content="🗑 Delete"
                                Style="{StaticResource ActionDangerBtn}"
                                Click="DeleteBtn_Click"
                                Visibility="Collapsed"/>
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="EditBtn"
                                    Content="✏ Edit"
                                    Style="{StaticResource ActionBtn}"
                                    Margin="0,0,6,0"
                                    Click="EditBtn_Click"
                                    Visibility="Collapsed"/>
                            <Button x:Name="AmendBtn"
                                    Content="📝 Add amendment"
                                    Style="{StaticResource ActionBtn}"
                                    Margin="0,0,6,0"
                                    Click="AmendBtn_Click"
                                    Visibility="Collapsed"/>
                            <Button x:Name="OpenPdfBtn"
                                    Content="📄 Open PDF"
                                    Style="{StaticResource ActionBtn}"
                                    Click="OpenPdfBtn_Click"
                                    Visibility="Collapsed"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Detail scroll area -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="DetailPanel"
                                Visibility="Collapsed"
                                Margin="20,16,20,24">

                        <!-- Hero card -->
                        <Border x:Name="HeroCard"
                                CornerRadius="10"
                                Padding="20,16"
                                Margin="0,0,0,16">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="{DynamicResource HeroBgStartColor}" Offset="0"/>
                                    <GradientStop Color="{DynamicResource HeroBgEndColor}"   Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel>
                                <TextBlock x:Name="DetailId"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource HeroNumFgBrush}"/>
                                <TextBlock x:Name="DetailSubject"
                                           FontSize="16" FontWeight="SemiBold"
                                           Foreground="{DynamicResource HeroTitleFgBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,0"/>
                                <TextBlock x:Name="DetailSeries"
                                           FontSize="12"
                                           Foreground="{DynamicResource HeroSubjectFgBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,10"/>
                                <WrapPanel>
                                    <Border x:Name="StatusBadgeControl"
                                            CornerRadius="10" Padding="10,3" Margin="0,0,6,4">
                                        <TextBlock x:Name="DetailStatus"
                                                   FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                    <TextBlock x:Name="VersionCountLabel"
                                               FontSize="11"
                                               Foreground="#8A9BC0"
                                               VerticalAlignment="Center"
                                               Margin="0,0,0,4"/>
                                    <Border x:Name="PdfBadge"
                                            Background="#18FFFFFF" BorderBrush="#22FFFFFF"
                                            BorderThickness="1"
                                            CornerRadius="10" Padding="9,3" Margin="6,0,0,4"
                                            Visibility="Collapsed">
                                        <TextBlock Text="📎 PDF attached"
                                                   FontSize="11" Foreground="#B8CEF0"/>
                                    </Border>
                                    <Border x:Name="AmendsPanel"
                                            Background="#18FFFFFF" BorderBrush="#22FFFFFF"
                                            BorderThickness="1"
                                            CornerRadius="10" Padding="9,3" Margin="6,0,0,4"
                                            Visibility="Collapsed">
                                        <TextBlock x:Name="AmendsLabel" FontSize="11" Foreground="#A8C0E8"/>
                                    </Border>
                                    <Border x:Name="RepealedByPanel"
                                            Background="#22FF4444" BorderBrush="#44FF4444"
                                            BorderThickness="1"
                                            CornerRadius="10" Padding="9,3" Margin="6,0,0,4"
                                            Visibility="Collapsed">
                                        <TextBlock x:Name="RepealedByLabel" FontSize="11" Foreground="#FFAAAA"/>
                                    </Border>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <!-- Action buttons row (edit / add amendment / open PDF) -->
                        <StackPanel x:Name="InlineActionRow"
                                    Orientation="Horizontal"
                                    Margin="0,0,0,16"
                                    Visibility="Collapsed">
                            <Button x:Name="InlineEditBtn"
                                    Content="✏ Edit"
                                    Style="{StaticResource ActionBtn}"
                                    Margin="0,0,6,0"
                                    Click="EditBtn_Click"
                                    Visibility="Collapsed"/>
                            <Button x:Name="InlineAmendBtn"
                                    Content="📝 Add amendment"
                                    Style="{StaticResource ActionBtn}"
                                    Margin="0,0,6,0"
                                    Click="AmendBtn_Click"
                                    Visibility="Collapsed"/>
                            <Button x:Name="InlineOpenPdfBtn"
                                    Content="📄 Open PDF"
                                    Style="{StaticResource ActionBtn}"
                                    Click="OpenPdfBtn_Click"
                                    Visibility="Collapsed"/>
                        </StackPanel>

                        <!-- Metadata -->
                        <TextBlock Text="METADATA"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   Margin="0,0,0,8"/>
                        <UniformGrid x:Name="MetadataGrid" Columns="2" Margin="0,0,0,16"/>

                        <!-- Current version -->
                        <TextBlock Text="CURRENT VERSION"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   Margin="0,0,0,8"/>
                        <Border x:Name="LatestVersionCard"
                                BorderBrush="{DynamicResource BorderThinBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Margin="0,0,0,16"
                                Visibility="Collapsed">
                            <StackPanel>
                                <Border x:Name="VersionCardHeader"
                                        Background="{DynamicResource VersionHeaderBgBrush}"
                                        BorderBrush="{DynamicResource BorderThinBrush}"
                                        BorderThickness="0,0,0,1"
                                        CornerRadius="8,8,0,0"
                                        Padding="14,9">
                                    <DockPanel>
                                        <TextBlock x:Name="VersionNumLabel"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock x:Name="VersionDateLabel"
                                                   DockPanel.Dock="Right"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextTertiaryBrush}"/>
                                    </DockPanel>
                                </Border>
                                <StackPanel x:Name="LatestVersionPanel" Margin="14,12"/>
                            </StackPanel>
                        </Border>

                        <!-- Version history -->
                        <TextBlock x:Name="HistoryHeader"
                                   Text="VERSION HISTORY"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   Margin="0,0,0,8"
                                   Visibility="Collapsed"/>
                        <ItemsControl x:Name="VersionHistoryList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Grid.Column="0"
                                                 Width="8" Height="8"
                                                 Fill="{DynamicResource BorderMedBrush}"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Top"
                                                 Margin="0,6,0,0"/>
                                        <Border Grid.Column="1"
                                                BorderBrush="{DynamicResource BorderThinBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="12,10">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" FontSize="12"
                                                           Foreground="{DynamicResource TextPrimaryBrush}">
                                                    <Run Text="Version "/>
                                                    <Run Text="{Binding VersionNumber}"/>
                                                    <Run Text=" — "/>
                                                    <Run Text="{Binding Title}"/>
                                                </TextBlock>
                                                <TextBlock Margin="0,4,0,0" FontSize="11"
                                                           Foreground="{DynamicResource TextTertiaryBrush}">
                                                    <Run Text="Enacted: " FontWeight="SemiBold"/>
                                                    <Run Text="{Binding DateEnacted}"/>
                                                    <Run Text="  ·  "/>
                                                    <Run Text="{Binding EnactedBy}"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Content}"
                                                           TextWrapping="Wrap" FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Margin="0,4,0,0"/>
                                                <Border Margin="0,6,0,0" CornerRadius="6" Padding="8,6"
                                                        Background="{DynamicResource VersionNotesBgBrush}"
                                                        Visibility="{Binding AmendmentNotes,
                                                            Converter={StaticResource NullToVisibility}}">
                                                    <TextBlock Text="{Binding AmendmentNotes}"
                                                               TextWrapping="Wrap" FontSize="11"
                                                               FontStyle="Italic"
                                                               Foreground="{DynamicResource VersionNotesFgBrush}"/>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Grid>
    </DockPanel>
</UserControl>
