<Window x:Class="LLOIS.Views.AuditLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LLOIS — Audit Log" Height="600" Width="860"
        WindowStartupLocation="CenterOwner" Loaded="Window_Loaded">

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#1a3a6b" Padding="16,12">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="✖ Close" Width="90"
                        Background="White" FontWeight="SemiBold"
                        Click="CloseBtn_Click"/>
                <TextBlock Text="🔍 Audit Log" Foreground="White"
                           FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <Border DockPanel.Dock="Top" Background="#F5F7FF" Padding="12,8"
                BorderBrush="#DDEEFF" BorderThickness="0,0,0,1">
            <TextBlock x:Name="RecordCount" VerticalAlignment="Center"
                       Foreground="Gray" FontSize="12"/>
        </Border>

        <DataGrid x:Name="AuditGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  RowHeaderWidth="0"
                  AlternatingRowBackground="#F8F9FF"
                  CanUserSortColumns="True"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Timestamp"
                    Binding="{Binding Timestamp, StringFormat=\{0:MM/dd/yyyy HH:mm:ss\}}"
                    Width="160"/>
                <DataGridTextColumn Header="User"
                    Binding="{Binding Username}" Width="130"/>
                <DataGridTextColumn Header="Action"
                    Binding="{Binding Action}" Width="110"/>
                <DataGridTextColumn Header="Details"
                    Binding="{Binding Details}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>