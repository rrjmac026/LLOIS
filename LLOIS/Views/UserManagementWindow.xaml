<Window x:Class="LLOIS.Views.UserManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LLOIS — User Management" Height="500" Width="700"
        WindowStartupLocation="CenterOwner" Loaded="Window_Loaded">

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#2d0a4e" Padding="16,12">
            <TextBlock Text="👥 User Management (Admin)" Foreground="White"
                       FontSize="15" FontWeight="Bold"/>
        </Border>

        <!-- Action Bar -->
        <Border DockPanel.Dock="Top" Background="#F8F5FF" BorderBrush="#E0D8FF"
                BorderThickness="0,0,0,1" Padding="12,8">
            <StackPanel Orientation="Horizontal">
                <Button Content="➕ Add User" Width="110" Margin="0,0,8,0"
                        Click="AddUserBtn_Click"/>
                <Button Content="🔑 Reset Password" Width="130" Margin="0,0,8,0"
                        Click="ResetPasswordBtn_Click"/>
                <Button Content="Deactivate" Width="100" Margin="0,0,8,0"
                        Click="DeactivateBtn_Click"/>
                <Button Content="Reactivate" Width="100"
                        Click="ReactivateBtn_Click"/>
            </StackPanel>
        </Border>

        <DataGrid x:Name="UsersGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  RowHeaderWidth="0"
                  AlternatingRowBackground="#F8F5FF"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="160"/>
                <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="120"/>
                <DataGridTextColumn Header="Active" Binding="{Binding IsActive}" Width="80"/>
                <DataGridTextColumn Header="Created" Binding="{Binding CreatedAt, StringFormat=\{0:MM/dd/yyyy\}}" Width="110"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
