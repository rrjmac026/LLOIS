<Window x:Class="LLOIS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:LLOIS"
        Title="LLOIS - Local Legislative Ordinance Information System"
        Height="600" Width="950" MinHeight="500" MinWidth="750">

    <Window.Resources>
        <Style x:Key="StatusBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,3"/>
        </Style>
        <local:NullToVisibilityConverter x:Key="NullToVisibility"/>
    </Window.Resources>

    <DockPanel Margin="12">

        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
            <TextBlock Text="🏛️ Local Legislative Ordinance Information System"
                       FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>

            <!-- Search Bar -->
            <DockPanel Margin="0,0,0,6">
                <Button DockPanel.Dock="Right" Content="Search" Width="80"
                        Margin="6,0,0,0" Click="SearchButton_Click"/>
                <TextBox x:Name="SearchBox" FontSize="14" Padding="6,4"
                         KeyDown="SearchBox_KeyDown"
                         Text="Search by ID, subject, or series number..."/>
            </DockPanel>

            <!-- Status Filter -->
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Filter by status:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="StatusFilter" Width="130" SelectionChanged="StatusFilter_Changed">
                    <ComboBoxItem Content="All" IsSelected="True"/>
                    <ComboBoxItem Content="In Effect"/>
                    <ComboBoxItem Content="Amended"/>
                    <ComboBoxItem Content="Superseded"/>
                    <ComboBoxItem Content="Repealed"/>
                </ComboBox>
            </StackPanel>
        </StackPanel>

        <!-- Main Content: List + Detail -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Results List -->
            <DockPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock DockPanel.Dock="Top" x:Name="ResultCount"
                           Text="All ordinances" FontSize="12"
                           Foreground="Gray" Margin="0,0,0,4"/>
                <ListBox x:Name="OrdinanceList"
                         SelectionChanged="OrdinanceList_SelectionChanged"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4">
                                <TextBlock Text="{Binding Id}" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="{Binding Subject}" FontSize="11"
                                           Foreground="Gray" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Status}" FontSize="11"
                                           Foreground="SteelBlue" Margin="0,2,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Right: Detail Panel -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="DetailPanel" Visibility="Collapsed">

                    <!-- Ordinance Header -->
                    <Border Background="#F0F4FF" CornerRadius="6" Padding="12" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock x:Name="DetailId" FontSize="13" Foreground="Gray"/>
                            <TextBlock x:Name="DetailSubject" FontSize="16"
                                       FontWeight="Bold" TextWrapping="Wrap" Margin="0,4,0,6"/>
                            <StackPanel Orientation="Horizontal">
                                <Border x:Name="StatusBadgeControl" CornerRadius="4" Padding="8,3">
                                    <TextBlock x:Name="DetailStatus" FontSize="12" FontWeight="SemiBold"/>
                                </Border>
                                <TextBlock x:Name="DetailSeries" FontSize="12"
                                           Foreground="Gray" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Latest Version -->
                    <TextBlock Text="📋 Current / Latest Version" FontSize="14"
                               FontWeight="Bold" Margin="0,0,0,6"/>
                    <Border BorderBrush="#CCDDFF" BorderThickness="1"
                            CornerRadius="6" Padding="12" Margin="0,0,0,12">
                        <StackPanel x:Name="LatestVersionPanel"/>
                    </Border>

                    <!-- Version History -->
                    <TextBlock x:Name="HistoryHeader" Text="🕓 Version History"
                               FontSize="14" FontWeight="Bold" Margin="0,0,0,6"/>
                    <ItemsControl x:Name="VersionHistoryList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#E0E0E0" BorderThickness="1"
                                        CornerRadius="6" Padding="10" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" FontSize="13">
                                            <Run Text="Version "/>
                                            <Run Text="{Binding VersionNumber}"/>
                                            <Run Text=" — "/>
                                            <Run Text="{Binding Title}"/>
                                        </TextBlock>
                                        <TextBlock Margin="0,4,0,0">
                                            <Run Text="Enacted: " FontWeight="SemiBold"/>
                                            <Run Text="{Binding DateEnacted}"/>
                                            <Run Text="  |  "/>
                                            <Run Text="{Binding EnactedBy}"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Content}" TextWrapping="Wrap"
                                                   Foreground="Gray" Margin="0,4,0,0"/>
                                        <TextBlock Text="{Binding AmendmentNotes}" TextWrapping="Wrap"
                                                   Foreground="#CC6600" FontStyle="Italic" Margin="0,4,0,0"
                                                   Visibility="{Binding AmendmentNotes, Converter={StaticResource NullToVisibility}}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Window>