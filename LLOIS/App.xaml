<Application x:Class="LLOIS.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:LLOIS">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Default to Light theme; swapped at runtime by ThemeService -->
                <ResourceDictionary Source="Themes/LightTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- ── Converters ──────────────────────────────────── -->
            <local:NullToVisibilityConverter x:Key="NullToVisibility"/>

            <!-- ── Shared TextBox with placeholder ───────────────
                 Tag = placeholder text.
                 Colors come from theme brushes so they flip with dark mode. -->
            <Style x:Key="PlaceholderTextBox" TargetType="TextBox">
                <Setter Property="Padding"     Value="8,6"/>
                <Setter Property="FontSize"    Value="13"/>
                <Setter Property="Foreground"  Value="{DynamicResource TextPrimaryBrush}"/>
                <Setter Property="Background"  Value="{DynamicResource BgPrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderThinBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <Grid>
                                    <ScrollViewer x:Name="PART_ContentHost"
                                                  Margin="{TemplateBinding Padding}"/>
                                    <TextBlock x:Name="Placeholder"
                                               Text="{TemplateBinding Tag}"
                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                               Margin="{TemplateBinding Padding}"
                                               VerticalAlignment="Center"
                                               IsHitTestVisible="False"
                                               Visibility="Collapsed"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="Text"             Value=""/>
                                        <Condition Property="IsKeyboardFocused" Value="False"/>
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                                </MultiTrigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter Property="BorderBrush" Value="{DynamicResource BrandBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ── Topbar button ──────────────────────────────── -->
            <Style x:Key="TopbarBtn" TargetType="Button">
                <Setter Property="Padding"          Value="10,5"/>
                <Setter Property="Margin"           Value="0,0,6,0"/>
                <Setter Property="FontSize"         Value="12"/>
                <Setter Property="FontWeight"       Value="Medium"/>
                <Setter Property="Foreground"       Value="{DynamicResource TopbarBtnFgBrush}"/>
                <Setter Property="Background"       Value="{DynamicResource TopbarBtnBgBrush}"/>
                <Setter Property="BorderThickness"  Value="0"/>
                <Setter Property="Cursor"           Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.8"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.65"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="TopbarDangerBtn" TargetType="Button" BasedOn="{StaticResource TopbarBtn}">
                <Setter Property="Foreground" Value="{DynamicResource TopbarDangerFgBrush}"/>
                <Setter Property="Background" Value="{DynamicResource TopbarDangerBgBrush}"/>
            </Style>

            <!-- ── Action bar button (inside detail pane) ────── -->
            <Style x:Key="ActionBtn" TargetType="Button">
                <Setter Property="Padding"         Value="10,5"/>
                <Setter Property="FontSize"        Value="12"/>
                <Setter Property="FontWeight"      Value="Medium"/>
                <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}"/>
                <Setter Property="Background"      Value="{DynamicResource BgPrimaryBrush}"/>
                <Setter Property="BorderBrush"     Value="{DynamicResource BorderThinBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background"
                                            Value="{DynamicResource BgHoverBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Background"
                                            Value="{DynamicResource BgActiveBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ActionDangerBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
                <Setter Property="Foreground"  Value="{DynamicResource DangerFgBrush}"/>
                <Setter Property="Background"  Value="{DynamicResource DangerBgBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource DangerBorderBrush}"/>
            </Style>

            <!-- ── Add ordinance button ───────────────────────── -->
            <Style x:Key="AddBtn" TargetType="Button">
                <Setter Property="Padding"        Value="12,6"/>
                <Setter Property="FontSize"       Value="12"/>
                <Setter Property="FontWeight"     Value="SemiBold"/>
                <Setter Property="Foreground"     Value="White"/>
                <Setter Property="Background"     Value="{DynamicResource AccentGreenBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor"         Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ── ComboBox shared ───────────────────────────── -->
            <Style TargetType="ComboBox">
                <Setter Property="Padding"         Value="8,5"/>
                <Setter Property="FontSize"        Value="13"/>
                <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}"/>
                <Setter Property="Background"      Value="{DynamicResource BgPrimaryBrush}"/>
                <Setter Property="BorderBrush"     Value="{DynamicResource BorderThinBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>

            <!-- ── DatePicker shared ─────────────────────────── -->
            <Style TargetType="DatePicker">
                <Setter Property="Height"          Value="32"/>
                <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}"/>
                <Setter Property="Background"      Value="{DynamicResource BgPrimaryBrush}"/>
                <Setter Property="BorderBrush"     Value="{DynamicResource BorderThinBrush}"/>
            </Style>

            <!-- ── ListBox / ListBoxItem ─────────────────────── -->
            <Style TargetType="ListBox">
                <Setter Property="Background"      Value="{DynamicResource BgPrimaryBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}"/>
            </Style>
            <Style TargetType="ListBoxItem">
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="Padding"         Value="0"/>
                <Setter Property="Background"      Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border x:Name="OuterBd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="3,0,0,0">
                                <Border x:Name="InnerBd"
                                        Background="Transparent"
                                        BorderBrush="{DynamicResource BorderThinBrush}"
                                        BorderThickness="0,0,0,1">
                                    <ContentPresenter Margin="0"/>
                                </Border>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="OuterBd" Property="Background"
                                            Value="{DynamicResource BgHoverBrush}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="OuterBd" Property="Background"
                                            Value="{DynamicResource SidebarActiveBgBrush}"/>
                                    <Setter TargetName="OuterBd" Property="BorderBrush"
                                            Value="{DynamicResource SidebarAccentBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ── DataGrid ──────────────────────────────────── -->
            <Style TargetType="DataGrid">
                <Setter Property="Background"            Value="{DynamicResource BgPrimaryBrush}"/>
                <Setter Property="Foreground"            Value="{DynamicResource TextPrimaryBrush}"/>
                <Setter Property="BorderBrush"           Value="{DynamicResource BorderThinBrush}"/>
                <Setter Property="RowBackground"         Value="{DynamicResource BgPrimaryBrush}"/>
                <Setter Property="AlternatingRowBackground" Value="{DynamicResource BgSecondaryBrush}"/>
                <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderThinBrush}"/>
            </Style>
            <Style TargetType="DataGridColumnHeader">
                <Setter Property="Background"    Value="{DynamicResource BgSecondaryBrush}"/>
                <Setter Property="Foreground"    Value="{DynamicResource TextSecondaryBrush}"/>
                <Setter Property="FontSize"      Value="11"/>
                <Setter Property="FontWeight"    Value="SemiBold"/>
                <Setter Property="Padding"       Value="10,7"/>
                <Setter Property="BorderBrush"   Value="{DynamicResource BorderThinBrush}"/>
                <Setter Property="BorderThickness" Value="0,0,0,1"/>
            </Style>
            <Style TargetType="DataGridRow">
                <Setter Property="Foreground"    Value="{DynamicResource TextPrimaryBrush}"/>
            </Style>
            <Style TargetType="DataGridCell">
                <Setter Property="Foreground"    Value="{DynamicResource TextPrimaryBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
            </Style>

            <!-- ── ScrollViewer ──────────────────────────────── -->
            <Style TargetType="ScrollViewer">
                <Setter Property="Background" Value="Transparent"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
