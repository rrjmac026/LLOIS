<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Core surfaces ─────────────────────────────────── -->
    <Color x:Key="BgPrimaryColor">#1A1D27</Color>
    <Color x:Key="BgSecondaryColor">#22263A</Color>
    <Color x:Key="BgTertiaryColor">#2A2F45</Color>
    <Color x:Key="BgHoverColor">#2E3450</Color>
    <Color x:Key="BgActiveColor">#333A58</Color>

    <!-- ── Text ──────────────────────────────────────────── -->
    <Color x:Key="TextPrimaryColor">#E8ECF4</Color>
    <Color x:Key="TextSecondaryColor">#A0AABE</Color>
    <Color x:Key="TextTertiaryColor">#5A6480</Color>
    <Color x:Key="TextOnDarkColor">#FFFFFF</Color>

    <!-- ── Brand / accent ────────────────────────────────── -->
    <Color x:Key="BrandColor">#3B6AC8</Color>
    <Color x:Key="BrandLightColor">#4A7AD8</Color>
    <Color x:Key="BrandVeryLightColor">#1E2D50</Color>
    <Color x:Key="AccentGreenColor">#22A04A</Color>
    <Color x:Key="AccentGreenLightColor">#132F1C</Color>
    <Color x:Key="AccentGreenTextColor">#6EE89A</Color>

    <!-- ── Borders ────────────────────────────────────────── -->
    <Color x:Key="BorderThinColor">#2E3450</Color>
    <Color x:Key="BorderMedColor">#3A4060</Color>

    <!-- ── Status badges ─────────────────────────────────── -->
    <Color x:Key="StatusInEffectBgColor">#132F1C</Color>
    <Color x:Key="StatusInEffectFgColor">#6EE89A</Color>
    <Color x:Key="StatusAmendedBgColor">#2E2008</Color>
    <Color x:Key="StatusAmendedFgColor">#FACC65</Color>
    <Color x:Key="StatusRepealedBgColor">#2E0F0F</Color>
    <Color x:Key="StatusRepealedFgColor">#FC8080</Color>
    <Color x:Key="StatusReviewBgColor">#222638</Color>
    <Color x:Key="StatusReviewFgColor">#94A3B8</Color>
    <Color x:Key="StatusSupersededBgColor">#1A2040</Color>
    <Color x:Key="StatusSupersededFgColor">#7BA8F8</Color>

    <!-- ── Danger ─────────────────────────────────────────── -->
    <Color x:Key="DangerBgColor">#2E0F0F</Color>
    <Color x:Key="DangerFgColor">#FC8080</Color>
    <Color x:Key="DangerBorderColor">#7A2020</Color>

    <!-- ── Topbar ─────────────────────────────────────────── -->
    <Color x:Key="TopbarBgColor">#131726</Color>
    <Color x:Key="TopbarBtnBgColor">#1E2540</Color>
    <Color x:Key="TopbarBtnFgColor">#A8C0E8</Color>
    <Color x:Key="TopbarDangerBgColor">#3A1010</Color>
    <Color x:Key="TopbarDangerFgColor">#FC9090</Color>
    <Color x:Key="TopbarUserFgColor">#6890C8</Color>

    <!-- ── Hero card ──────────────────────────────────────── -->
    <Color x:Key="HeroBgStartColor">#1A2540</Color>
    <Color x:Key="HeroBgEndColor">#1E2D4E</Color>
    <Color x:Key="HeroNumFgColor">#6890C8</Color>
    <Color x:Key="HeroTitleFgColor">#E8ECF4</Color>
    <Color x:Key="HeroSubjectFgColor">#8AA8CC</Color>

    <!-- ── Sidebar ────────────────────────────────────────── -->
    <Color x:Key="SidebarAccentColor">#4A7AD8</Color>
    <Color x:Key="SidebarActiveBgColor">#1E2D50</Color>

    <!-- ── Version card ───────────────────────────────────── -->
    <Color x:Key="VersionHeaderBgColor">#22263A</Color>
    <Color x:Key="VersionNotesBgColor">#2E2008</Color>
    <Color x:Key="VersionNotesFgColor">#FACC65</Color>

    <!-- ── Brushes ────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BgPrimaryBrush"       Color="{StaticResource BgPrimaryColor}"/>
    <SolidColorBrush x:Key="BgSecondaryBrush"     Color="{StaticResource BgSecondaryColor}"/>
    <SolidColorBrush x:Key="BgTertiaryBrush"      Color="{StaticResource BgTertiaryColor}"/>
    <SolidColorBrush x:Key="BgHoverBrush"         Color="{StaticResource BgHoverColor}"/>
    <SolidColorBrush x:Key="BgActiveBrush"        Color="{StaticResource BgActiveColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"     Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"   Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextTertiaryBrush"    Color="{StaticResource TextTertiaryColor}"/>
    <SolidColorBrush x:Key="TextOnDarkBrush"      Color="{StaticResource TextOnDarkColor}"/>
    <SolidColorBrush x:Key="BrandBrush"           Color="{StaticResource BrandColor}"/>
    <SolidColorBrush x:Key="BrandLightBrush"      Color="{StaticResource BrandLightColor}"/>
    <SolidColorBrush x:Key="BrandVeryLightBrush"  Color="{StaticResource BrandVeryLightColor}"/>
    <SolidColorBrush x:Key="AccentGreenBrush"     Color="{StaticResource AccentGreenColor}"/>
    <SolidColorBrush x:Key="AccentGreenLightBrush"Color="{StaticResource AccentGreenLightColor}"/>
    <SolidColorBrush x:Key="AccentGreenTextBrush" Color="{StaticResource AccentGreenTextColor}"/>
    <SolidColorBrush x:Key="BorderThinBrush"      Color="{StaticResource BorderThinColor}"/>
    <SolidColorBrush x:Key="BorderMedBrush"       Color="{StaticResource BorderMedColor}"/>
    <SolidColorBrush x:Key="TopbarBgBrush"        Color="{StaticResource TopbarBgColor}"/>
    <SolidColorBrush x:Key="TopbarBtnBgBrush"     Color="{StaticResource TopbarBtnBgColor}"/>
    <SolidColorBrush x:Key="TopbarBtnFgBrush"     Color="{StaticResource TopbarBtnFgColor}"/>
    <SolidColorBrush x:Key="TopbarDangerBgBrush"  Color="{StaticResource TopbarDangerBgColor}"/>
    <SolidColorBrush x:Key="TopbarDangerFgBrush"  Color="{StaticResource TopbarDangerFgColor}"/>
    <SolidColorBrush x:Key="TopbarUserFgBrush"    Color="{StaticResource TopbarUserFgColor}"/>
    <SolidColorBrush x:Key="HeroNumFgBrush"       Color="{StaticResource HeroNumFgColor}"/>
    <SolidColorBrush x:Key="HeroTitleFgBrush"     Color="{StaticResource HeroTitleFgColor}"/>
    <SolidColorBrush x:Key="HeroSubjectFgBrush"   Color="{StaticResource HeroSubjectFgColor}"/>
    <SolidColorBrush x:Key="SidebarAccentBrush"   Color="{StaticResource SidebarAccentColor}"/>
    <SolidColorBrush x:Key="SidebarActiveBgBrush" Color="{StaticResource SidebarActiveBgColor}"/>
    <SolidColorBrush x:Key="VersionHeaderBgBrush" Color="{StaticResource VersionHeaderBgColor}"/>
    <SolidColorBrush x:Key="VersionNotesBgBrush"  Color="{StaticResource VersionNotesBgColor}"/>
    <SolidColorBrush x:Key="VersionNotesFgBrush"  Color="{StaticResource VersionNotesFgColor}"/>
    <SolidColorBrush x:Key="DangerBgBrush"        Color="{StaticResource DangerBgColor}"/>
    <SolidColorBrush x:Key="DangerFgBrush"        Color="{StaticResource DangerFgColor}"/>
    <SolidColorBrush x:Key="DangerBorderBrush"    Color="{StaticResource DangerBorderColor}"/>
    <SolidColorBrush x:Key="StatusInEffectBgBrush"Color="{StaticResource StatusInEffectBgColor}"/>
    <SolidColorBrush x:Key="StatusInEffectFgBrush"Color="{StaticResource StatusInEffectFgColor}"/>
    <SolidColorBrush x:Key="StatusAmendedBgBrush" Color="{StaticResource StatusAmendedBgColor}"/>
    <SolidColorBrush x:Key="StatusAmendedFgBrush" Color="{StaticResource StatusAmendedFgColor}"/>
    <SolidColorBrush x:Key="StatusRepealedBgBrush"Color="{StaticResource StatusRepealedBgColor}"/>
    <SolidColorBrush x:Key="StatusRepealedFgBrush"Color="{StaticResource StatusRepealedFgColor}"/>
    <SolidColorBrush x:Key="StatusReviewBgBrush"  Color="{StaticResource StatusReviewBgColor}"/>
    <SolidColorBrush x:Key="StatusReviewFgBrush"  Color="{StaticResource StatusReviewFgColor}"/>
    <SolidColorBrush x:Key="StatusSupersededBgBrush" Color="{StaticResource StatusSupersededBgColor}"/>
    <SolidColorBrush x:Key="StatusSupersededFgBrush" Color="{StaticResource StatusSupersededFgColor}"/>

</ResourceDictionary>
